<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1976D2"
        app:title="URLを追加"
        app:titleTextColor="#FFFFFF" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- URL入力 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="12dp"
                android:hint="https://example.com"
                android:hintTextColor="#AAAAAA"
                android:textColor="#222222"
                android:textSize="15sp"
                android:inputType="textUri"
                android:imeOptions="actionNext"/>

            <!-- URL取得中インジケーター -->
            <LinearLayout
                android:id="@+id/layoutFetching"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:visibility="gone">
                <ProgressBar
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    style="?android:attr/progressBarStyleSmall"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="サイト情報を取得中..."
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- サイト名 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="サイト名"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="12dp"
                android:hint="サイト名（自動入力されます）"
                android:hintTextColor="#AAAAAA"
                android:textColor="#222222"
                android:textSize="15sp"
                android:inputType="text"/>

            <!-- 監視間隔 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="監視間隔"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerInterval"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="12dp"/>

            <!-- CSSセレクター -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CSSセレクター（省略可）"
                android:textSize="14sp"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etSelector"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="12dp"
                android:hint="例: #main-content"
                android:hintTextColor="#AAAAAA"
                android:textColor="#222222"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:inputType="text"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="特定の箇所だけ監視したい場合に指定"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="保存して監視開始"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_primary"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
